# Base de données PostgreSQL (en local, fournie par `netlify dev` — voir .netlify/state.json ;
# en production, Netlify injecte automatiquement NETLIFY_DATABASE_URL)
DATABASE_URL="postgres://user@host:port/dbname"

# Secret utilisé pour signer les cookies de session (générer avec: openssl rand -hex 32)
SESSION_SECRET="change-me-to-a-random-64-char-hex-string"

# Compte fondateur créé par le script de seed
FOUNDER_EMAIL="fondateur@lextase.local"
FOUNDER_USERNAME="fondateur"
FOUNDER_PASSWORD="change-me-strong-password"

# URL publique du site (utilisée pour les cookies "secure" et les liens)
APP_URL="http://localhost:3000"

# Paiement (Stripe) — laisser vide désactive proprement les boutons de
# paiement des abonnements créateur, le reste du site continue de
# fonctionner. Voir le README pour la config.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Devise utilisée pour les abonnements créateur (prix fixé par chaque créateur·rice)
STRIPE_CURRENCY="eur"
